    # Resolve Git metadata for sandboxing
    # ...

    model = starting_model or "gemini-3.1-pro-preview"
    print(f"--- Spawning sub-agent with model: {model} ---")
    cmd = [
        "gemini", 
        "--model", model, 
        "--policy", policy_dir, 
        "--include-directories", project_root, 
        "--include-directories", os.path.join(project_root, ".beads"), 
        "--include-directories", git_common_dir,
        "--include-directories", git_dir,
        "--yolo", 
        "-p", directive
    ]
    
    log_file = open(log_path, "a")
    process = subprocess.Popen(
        cmd,
        stdout=log_file,
        stderr=log_file,
        cwd=worktree_path,
        env=env,
        start_new_session=True
    )
    log_file.close()

    registry_path = os.path.join(telemetry_dir, "active_scvs.json")
    
    # Add the new SCV to the registry
    new_registry_entry = {
        "pid": process.pid,
        "agent_name": agent_name,
        "model": model
    }

    with _registry_lock:
        try:
            lock_path = registry_path + ".lock"
            with FileLock(lock_path, timeout=10):
                try:
                    if os.path.exists(registry_path):
                        with open(registry_path, "r") as f:
                            registry = json.load(f)
                    else:
                        registry = {}
                except (json.JSONDecodeError, IOError):
                    registry = {}
                
                registry[objective_id] = new_registry_entry
                
                # Use atomic_write_json to update the registry
                atomic_write_json(registry_path, registry)

        except Timeout:
            print(f"Warning: Could not acquire lock for {registry_path}")
            # If we can't acquire the lock, we can't update the registry.
            # The spawned process might still be running, but Adjutant won't know about it.
            # This is a potential issue, but less severe than losing the whole registry.
            # Consider logging this more prominently or implementing a retry mechanism if needed.
            pass
        except Exception as e:
            print(f"Error updating SCV registry: {e}")
            # If writing the registry failed, we should probably terminate the spawned process
            # to avoid it running without being tracked.
            if process:
                try:
                    process.terminate()
                    process.wait(timeout=1.0)
                    print(f"Terminated spawned process {process.pid} due to registry write failure.")
                except Exception as term_e:
                    print(f"Failed to terminate process {process.pid}: {term_e}")
            pass


    print(f"Spawned {agent_name} for {objective_id}. Logging to {log_path}")

