```python
import os
import subprocess
import sys
import threading
import json
from filelock import FileLock, Timeout
import tempfile # Import tempfile module

# ... other imports and functions ...

def atomic_write_json(file_path: str, data: dict):
    """Atomically writes dictionary data to a JSON file."""
    temp_file = None
    try:
        # Create a temporary file in the same directory as the target file
        # This ensures atomic rename across filesystems.
        fd, temp_file = tempfile.mkstemp(dir=os.path.dirname(file_path), text=True)
        
        with os.fdopen(fd, 'w') as f:
            json.dump(data, f, indent=2)
        
        # Atomically replace the original file with the temporary file
        os.replace(temp_file, file_path)
    except Exception as e:
        print(f"Error during atomic write to {file_path}: {e}")
        # If an error occurs, clean up the temporary file if it was created
        if temp_file and os.path.exists(temp_file):
            try:
                os.remove(temp_file)
            except OSError as rm_e:
                print(f"Error removing temporary file {temp_file}: {rm_e}")
        raise # Re-raise the exception to indicate failure
    finally:
        # Ensure temp_file is removed if it exists and was not renamed
        if temp_file and os.path.exists(temp_file):
            try:
                os.remove(temp_file)
            except OSError as rm_e:
                print(f"Error removing temporary file {temp_file} in finally block: {rm_e}")


# ... (rest of the file) ...

def spawn_agent(agent_name: str, objective_id: str, starting_model: str = None, directive: str = "Execute mission."):
